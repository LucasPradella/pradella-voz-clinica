# Copy this file to .env and fill in the values.
# NEVER commit .env with real secrets.

# PostgreSQL connection string
DATABASE_URL=postgres://pradella:dev@localhost:5432/pradella_dev?sslmode=disable

# JWT signing secret — must be at least 32 characters
JWT_SECRET=replace-with-at-least-32-chars-random-secret

# AI providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Stripe (optional for local development without billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Server port (default: 8080)
PORT=8080

# pgvector embedding dimension (must match the embedding model; default: 1536 for text-embedding-3-large)
EMBEDDING_DIM=1536
